# --- Option A : Discord (gratuit, pas besoin de Resend ni de Vercel Pro) ---
# Crée un webhook : Discord serveur → Paramètres du salon → Intégrations → Webhooks → Nouveau webhook
# Colle l'URL complète ici, puis sur Vercel : Settings → Environment Variables → DISCORD_WEBHOOK_URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# --- Option B : Email via Resend (compte gratuit sur resend.com) ---
RESEND_API_KEY=re_xxxxxxxx

# Optionnel : email qui reçoit les notifications (défaut : info@dygroup.co)
# WAITLIST_NOTIFY_EMAIL=info@dygroup.co

# Optionnel : expéditeur après vérification du domaine sur Resend
# RESEND_FROM=Dress You <noreply@dygroup.co>
