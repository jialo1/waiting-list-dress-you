# Resend (https://resend.com) - requis pour envoyer un email à l'équipe à chaque inscription
RESEND_API_KEY=re_xxxxxxxx

# Optionnel : email qui reçoit les notifications (défaut : info@dygroup.co)
# WAITLIST_NOTIFY_EMAIL=info@dygroup.co

# Optionnel : expéditeur (après vérification du domaine sur Resend, ex. "Dress You <noreply@dygroup.co>")
# Par défaut : onboarding@resend.dev (tests uniquement)
# RESEND_FROM=Dress You <onboarding@resend.dev>
